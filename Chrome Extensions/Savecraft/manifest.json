{
  "manifest_version": 3,
  "name": "SaveCraft",
  "version": "1.0",
  "description": "Your personal media library. Save movies, shows, music, books, and games you want to experience.",
  "permissions": ["storage", "contextMenus", "activeTab", "tabs", "declarativeNetRequestWithHostAccess"],
  "host_permissions": ["https://api.microlink.io/*", "https://firestore.googleapis.com/*", "https://identitytoolkit.googleapis.com/*", "https://securetoken.googleapis.com/*", "https://itunes.apple.com/*", "https://musicbrainz.org/*", "https://www.wikidata.org/*", "https://en.wikipedia.org/*", "https://www.googleapis.com/*", "https://www.youtube.com/*", "https://www.youtube-nocookie.com/*", "https://openlibrary.org/*", "https://store.steampowered.com/*", "https://api.steampowered.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "yt_referer_rules",
        "enabled": true,
        "path": "rules/youtube_referer_rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "SaveCraft"
  },
  "web_accessible_resources": [{
    "resources": ["images/logos/pngkey.com-rolling-stones-tongue-png-3135824.png", "images/logos/steam.png", "images/logos/votecraft-logo_white.png", "images/logos/votecraft_icon_white.png"],
    "matches": ["<all_urls>"]
  }],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
